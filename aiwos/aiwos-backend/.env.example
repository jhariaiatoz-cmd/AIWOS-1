# FastAPI configuration
PROJECT_NAME="AIWOS"
API_V1_STR="/api/v1"

# Database Configuration (Option A: Component settings for local PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aiwos

# Database Configuration (Option B: Connection String for Supabase / Production)
# If DATABASE_URL is set, it will override the individual component settings above.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
